{
  "manifest_version": 2,
  "name": "Restricted Insta",
  "version": "1.0",

  "description": "Restricts many functionalities of instagram.",

  "icons": {
    "48": "icon.svg"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "restricted-insta@froxot.de",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "content_scripts": [
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["main.js"]
    }
  ]
}